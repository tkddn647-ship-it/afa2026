# Pi에서 stm_ingest.env 로 복사 후 수정
# cp stm_ingest.env.example stm_ingest.env

# 로깅 서버 (CSV 기록)
INGEST_URL=http://3.39.188.80:8000/ingest

# 선택: 실시간 대시보드 (realtime_server.py, 포트 8011)
# REALTIME_URL=http://3.39.188.80:8011/api/live/ingest

DEVICE=raspberry-pi-stm
UART_PORT=/dev/ttyAMA0
UART_BAUD=460800
HTTP_TIMEOUT=0.8
